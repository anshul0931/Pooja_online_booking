<!-- 🌸 Static Hero Section -->
<section class="hero-static" style="background-image: url('<%= asset_path('ganeshji.webp') %>');">
  <div class="overlay"></div>
  <div class="hero-content">
    <h1>Our Spiritual Services</h1>
    <p>Offering authentic Vedic rituals, custom samagri seva, and spiritual guidance directly from Ujjain.</p>
  </div>
</section>

<!-- 🌸 Services Content Grid -->
<section class="our-services py-4">
  <div class="container px-0">
    <div class="row justify-content-center">
      <div class="col-lg-10 col-xl-9">
        
        <!-- Service 1 -->
        <div class="bg-white rounded-3 shadow-md border p-4 p-md-5 mb-4 scroll-reveal" data-controller="scroll-reveal">
          <div class="d-flex align-items-center gap-3 mb-3 border-bottom pb-2">
            <span class="fs-2 text-saffron"><i class="fa-solid fa-fire-burner"></i></span>
            <h2 class="h4 fw-bold mb-0" style="font-family: var(--font-heading);">Havan & Yagya Rituals</h2>
          </div>
          <p style="font-size: 1.05rem; color: var(--text-primary); line-height: 1.7; font-family: 'Noto Serif', serif;">
            Experience sacred Havans (such as Maha Rudra Havan, Navgrah Shanti Havan, and Baglamukhi Anushthan) performed directly by high-caliber pandits in Ujjain. 
            Excellent for resolving obstacles, home purification, business growth, and general family well-being.
          </p>
        </div>

        <!-- Service 2 -->
        <div class="bg-white rounded-3 shadow-md border p-4 p-md-5 mb-4 scroll-reveal" data-controller="scroll-reveal">
          <div class="d-flex align-items-center gap-3 mb-3 border-bottom pb-2">
            <span class="fs-2 text-saffron"><i class="fa-solid fa-om"></i></span>
            <h2 class="h4 fw-bold mb-0" style="font-family: var(--font-heading);">Dosha Nivaran Pujas</h2>
          </div>
          <p style="font-size: 1.05rem; color: var(--text-primary); line-height: 1.7; font-family: 'Noto Serif', serif;">
            Specialized planetary remedies such as Kaal Sarp Dosh Shanti, Mangalik Dosh Bhat Puja, Ark/Ghat Vivah, and Rin Mukti Seva conducted 
            at specific energetic centers in Ujjain. Complete with custom gotra recitation and live streaming clips.
          </p>
        </div>

        <!-- Service 3 -->
        <div class="bg-white rounded-3 shadow-md border p-4 p-md-5 mb-4 scroll-reveal" data-controller="scroll-reveal">
          <div class="d-flex align-items-center gap-3 mb-3 border-bottom pb-2">
            <span class="fs-2 text-saffron"><i class="fa-solid fa-hands-holding"></i></span>
            <h2 class="h4 fw-bold mb-0" style="font-family: var(--font-heading);">Pitru Tarpan & Pind Daan</h2>
          </div>
          <p style="font-size: 1.05rem; color: var(--text-primary); line-height: 1.7; font-family: 'Noto Serif', serif;">
            Conduct authentic Shradh, Pitru Tarpan, and Pind Daan rituals at the holy Siddhwat or Ram Ghat in Ujjain for the peace of ancestral souls, 
            bringing harmony, peace of mind, and clearing hurdles in lineage success.
          </p>
        </div>

        <!-- CTA -->
        <div class="text-center mt-5">
          <%= link_to new_custom_booking_path, class: "btn-premium btn-saffron px-5 py-3 fs-6 text-decoration-none" do %>
            🕉 Book Custom Seva
          <% end %>
        </div>

      </div>
    </div>
  </div>
</section>
