<!-- 🌸 Static Hero Section -->
<section class="hero-static" style="background-image: url('<%= asset_path('Mahakaleshwar.webp') %>');">
  <div class="overlay"></div>
  <div class="hero-content">
    <h1>Contact Our Pandits</h1>
    <p>Reach out to resolve custom puja queries, schedule live streams, or receive spiritual consulting from Ujjain.</p>
  </div>
</section>

<div class="container my-5" data-controller="contact">
  <div class="row justify-content-center g-4">

    <!-- 🕉 Contact Information Card (Left on desktop, top on mobile) -->
    <div class="col-lg-5 col-md-6 scroll-reveal" data-controller="scroll-reveal">
      <div class="bg-white p-4 p-md-5 rounded-3 shadow-md border h-100" style="border-top: 4px solid var(--gold-color);">
        <h2 class="h4 mb-4" style="font-family: var(--font-heading); font-weight: 700; color: var(--primary-color);">
          <i class="fa-solid fa-om text-saffron me-2"></i> Get In Touch
        </h2>

        <!-- Address -->
        <div class="d-flex align-items-start gap-3 mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                style="width: 42px; height: 42px; background: var(--accent-light);">
            <i class="fa-solid fa-location-dot" style="color: var(--secondary-color);"></i>
          </span>
          <div>
            <h3 class="h6 fw-bold mb-1" style="font-family: var(--font-heading); color: var(--primary-color);">Our Address</h3>
            <!-- TODO: Replace with actual business address -->
            <p class="mb-0" style="color: var(--text-muted); font-size: 14px; line-height: 1.6;">
              Mahakal Marg, Near Mahakaleshwar Temple,<br>
              Ujjain, Madhya Pradesh 456001, India
            </p>
          </div>
        </div>

        <!-- Email -->
        <div class="d-flex align-items-start gap-3 mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                style="width: 42px; height: 42px; background: var(--accent-light);">
            <i class="fa-solid fa-envelope" style="color: var(--secondary-color);"></i>
          </span>
          <div>
            <h3 class="h6 fw-bold mb-1" style="font-family: var(--font-heading); color: var(--primary-color);">Email</h3>
            <a href="mailto:info@ujjainbookmypooja.com" style="color: var(--text-muted); font-size: 14px; text-decoration: none;">
              info@ujjainbookmypooja.com
            </a>
          </div>
        </div>

        <!-- Phone -->
        <div class="d-flex align-items-start gap-3 mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                style="width: 42px; height: 42px; background: var(--accent-light);">
            <i class="fa-solid fa-phone" style="color: var(--secondary-color);"></i>
          </span>
          <div>
            <h3 class="h6 fw-bold mb-1" style="font-family: var(--font-heading); color: var(--primary-color);">Phone</h3>
            <a href="tel:+917987488586" style="color: var(--text-muted); font-size: 14px; text-decoration: none;">
              +91-7987488586
            </a>
          </div>
        </div>

        <!-- Business Hours -->
        <div class="d-flex align-items-start gap-3 mb-4">
          <span class="d-inline-flex align-items-center justify-content-center rounded-circle flex-shrink-0"
                style="width: 42px; height: 42px; background: var(--accent-light);">
            <i class="fa-regular fa-clock" style="color: var(--secondary-color);"></i>
          </span>
          <div>
            <h3 class="h6 fw-bold mb-1" style="font-family: var(--font-heading); color: var(--primary-color);">Business Hours</h3>
            <!-- TODO: Update with actual hours if different -->
            <p class="mb-0" style="color: var(--text-muted); font-size: 14px; line-height: 1.6;">
              Mon – Sat: 9:00 AM – 7:00 PM IST<br>
              Sunday: By Appointment Only
            </p>
          </div>
        </div>

        <!-- Divider -->
        <hr style="border-color: var(--border-color);">

        <!-- Social Media Links -->
        <div>
          <h3 class="h6 fw-bold mb-3" style="font-family: var(--font-heading); color: var(--primary-color);">Follow Us</h3>
          <div class="d-flex gap-3">
            <a href="#" aria-label="Facebook"
               class="d-inline-flex align-items-center justify-content-center rounded-circle"
               style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--primary-color), #54000C); color: #fff; transition: var(--transition-smooth);">
              <i class="fa-brands fa-facebook-f"></i>
            </a>
            <a href="#" aria-label="Instagram"
               class="d-inline-flex align-items-center justify-content-center rounded-circle"
               style="width: 40px; height: 40px; background: linear-gradient(135deg, var(--secondary-color), #BF360C); color: #fff; transition: var(--transition-smooth);">
              <i class="fa-brands fa-instagram"></i>
            </a>
            <a href="#" aria-label="YouTube"
               class="d-inline-flex align-items-center justify-content-center rounded-circle"
               style="width: 40px; height: 40px; background: linear-gradient(135deg, #c4302b, #8a1c18); color: #fff; transition: var(--transition-smooth);">
              <i class="fa-brands fa-youtube"></i>
            </a>
          </div>
        </div>

      </div>
    </div>

    <!-- 🔷 Form Column (Right on desktop, bottom on mobile) -->
    <div class="col-lg-7 col-md-6">

      <!-- Form Card (Visible by default) -->
      <div class="bg-white p-4 p-md-5 rounded-3 shadow-md border" data-contact-target="formCard">
        <h2 class="h4 text-center mb-4" style="font-family: var(--font-heading); font-weight:700;">
          Send Us a Message
        </h2>

        <%= form_with url: "/contact_submit", method: :post, local: true, html: { data: { contact_target: "form", action: "submit->contact#submit" }, novalidate: true } do |f| %>
          
          <div class="mb-3">
            <%= f.label :name, "Full Name *", class: "form-label" %>
            <%= f.text_field :name, 
                             class: "custom-input", 
                             placeholder: "Enter your full name", 
                             required: true,
                             data: { contact_target: "nameInput" } %>
            <div class="invalid-feedback">Please enter your name.</div>
          </div>

          <div class="mb-3">
            <%= f.label :email, "Email Address *", class: "form-label" %>
            <%= f.email_field :email, 
                              class: "custom-input", 
                              placeholder: "devotee@example.com", 
                              required: true %>
            <div class="invalid-feedback">Please enter a valid email address.</div>
          </div>

          <div class="mb-3">
            <%= f.label :phone, "Phone Number *", class: "form-label" %>
            <%= f.telephone_field :phone, 
                                  class: "custom-input", 
                                  placeholder: "e.g. 9876543210", 
                                  required: true, 
                                  pattern: "\\d{10,15}" %>
            <div class="invalid-feedback">A valid mobile number is required.</div>
          </div>

          <div class="mb-3">
            <%= f.label :message, "Query / Seva Requirements *", class: "form-label" %>
            <%= f.text_area :message, 
                            value: params[:message],
                            class: "custom-input", 
                            rows: 4, 
                            placeholder: "Write your questions or desired rituals...", 
                            required: true %>
            <div class="invalid-feedback">Please enter your message details.</div>
          </div>

          <div class="mt-4">
            <%= f.submit "Submit Query", class: "btn-premium btn-saffron w-100 py-3 fs-6" %>
          </div>
        <% end %>
      </div>

      <!-- 🔶 Success Card (Hidden by default, shown by Stimulus) -->
      <div class="bg-white p-4 p-md-5 rounded-3 shadow-lg border text-center d-none" 
           data-contact-target="successCard" 
           style="border-top: 5px solid var(--gold-color) !important;">
        <div class="mb-4">
          <span class="d-inline-flex justify-content-center align-items-center bg-light border border-success rounded-circle" style="width: 70px; height: 70px;">
            <i class="fa-solid fa-om text-saffron fs-2"></i>
          </span>
        </div>

        <h2 class="h3 fw-bold mb-2" style="font-family: var(--font-heading);">Message Sent!</h2>
        
        <div class="alert alert-warning border-0 p-3 my-4 text-start" style="background-color: var(--accent-light); color: var(--primary-color); font-size:15px; border-left: 4px solid var(--secondary-color) !important;">
          <strong>Om Namah Shivay!</strong> Thank you, <span class="success-name-placeholder fw-bold text-dark">Devotee</span>. 
          We have received your custom puja inquiry. Our designated temple pandit coordinator will review it and call or email you within 24 hours.
        </div>

        <%= link_to root_path, class: "btn-premium btn-maroon w-100 py-3 fs-6 text-decoration-none mt-2" do %>
          <i class="fa-solid fa-house me-2"></i> Back to Homepage
        <% end %>
      </div>

    </div>
  </div>
</div>
