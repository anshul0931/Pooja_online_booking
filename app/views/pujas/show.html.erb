<%
# Helper logic to match local assets contextually to Puja names
def local_image_for_puja(title)
  t = title.to_s.downcase
  if t.include?("kaal sarp") || t.include?("kalsarp")
    "kalsarp.webp"
  elsif t.include?("mangal") || t.include?("bhat") || t.include?("ark") || t.include?("vivah")
    "ganeshji.webp"
  elsif t.include?("abhishek") || t.include?("rudrabhishek") || t.include?("mrityunjaya") || t.include?("mahamrityunjaya") || t.include?("shiv")
    "Mahakaleshwar.webp"
  elsif t.include?("pitru") || t.include?("shradh") || t.include?("pind") || t.include?("pin_daan") || t.include?("pinda")
    "pin_daan.webp"
  elsif t.include?("rin") || t.include?("mukti")
    "Shree-Mahakaleshwar-Temple.webp"
  else
    "ganeshji.webp"
  end
end
%>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="row justify-content-center my-4">
  <div class="col-lg-10">
    <div class="bg-white rounded-3 shadow-md border overflow-hidden">
      <!-- Top banner image for puja -->
      <div style="position: relative; height: 350px; background-color: #333;">
        <% if @puja.image.attached? %>
          <%= image_tag @puja.image, style: "width:100%; height:100%; object-fit:cover;" %>
        <% else %>
          <%= image_tag local_image_for_puja(@puja.title), style: "width:100%; height:100%; object-fit:cover;" %>
        <% end %>
        <div style="position: absolute; inset:0; background: linear-gradient(to top, rgba(122,6,22,0.9), transparent 80%);"></div>
        <div style="position: absolute; bottom: 30px; left: 30px; right: 30px; color:#fff;">
          <span style="background-color: var(--gold-color); color:#2D2219; font-weight:700; font-size:12px; padding:4px 10px; border-radius:4px; text-transform:uppercase;">Vedic Seva</span>
          <h1 class="mt-2 text-white mb-0" style="font-family: var(--font-heading); font-size: 2.5rem; text-shadow: 0 2px 6px rgba(0,0,0,0.5);"><%= @puja.title %></h1>
        </div>
      </div>

      <!-- Content Section -->
      <div class="p-4 p-md-5">
        <div class="row g-5">
          <!-- Left details column -->
          <div class="col-md-7">
            <h3 class="fw-bold mb-3 border-bottom pb-2">Description & Spiritual Significance</h3>
            <p style="color: var(--text-primary); font-size: 1.05rem; line-height: 1.7; text-align: justify; font-family: 'Noto Serif', serif;">
              <%= @puja.description %>
            </p>
            
            <h3 class="fw-bold mt-5 mb-3 border-bottom pb-2">Ritual Deliverables</h3>
            <ul class="list-unstyled d-flex flex-column gap-2" style="font-size: 15px; color: var(--text-muted);">
              <li><i class="fa-solid fa-square-check text-success me-2"></i> Custom Sankalp conducted with devotee's Name and Gotra.</li>
              <li><i class="fa-solid fa-square-check text-success me-2"></i> Vedic chanting and rituals performed strictly by certified pandits.</li>
              <li><i class="fa-solid fa-square-check text-success me-2"></i> Free dispatch of sacred Prasad and Energized thread to your address.</li>
              <li><i class="fa-solid fa-square-check text-success me-2"></i> Devotees can pay easily after successful completion of rituals.</li>
            </ul>
          </div>

          <!-- Right booking summary column -->
          <div class="col-md-5">
            <div class="p-4 rounded-3" style="background-color: var(--bg-color); border: 1.5px solid var(--border-color);">
              <h4 class="fw-bold mb-4" style="font-family: var(--font-heading); text-align: center;">Seva Summary</h4>
              
              <div class="d-flex justify-content-between mb-3 border-bottom pb-2" style="font-size: 15px;">
                <span class="text-muted">Ritual Location:</span>
                <strong class="text-dark">Ujjain, MP</strong>
              </div>
              <div class="d-flex justify-content-between mb-3 border-bottom pb-2" style="font-size: 15px;">
                <span class="text-muted">Approx. Duration:</span>
                <strong class="text-dark"><%= @puja.duration_minutes || 60 %> Minutes</strong>
              </div>
              <div class="d-flex justify-content-between mb-4 pb-2" style="font-size: 15px;">
                <span class="text-muted">Payment Mode:</span>
                <strong class="text-success"><i class="fa-solid fa-shield-halved me-1"></i> Pay After Puja</strong>
              </div>

              <!-- Price Box -->
              <div class="text-center p-3 mb-4 rounded-3" style="background: var(--accent-light); border: 1px solid var(--gold-color);">
                <span style="font-size: 12px; font-weight:600; text-transform:uppercase; color: var(--text-muted); letter-spacing: 1px;">Base Offering Price</span>
                <div class="fs-1 fw-bold mt-1" style="color: var(--primary-color);">₹ <%= @puja.base_price.to_i %></div>
                <small class="text-muted">Includes complete Puja materials & priest fees</small>
              </div>

              <!-- Book Pooja CTA -->
              <div class="text-center">
                <%= link_to new_puja_booking_path(@puja), class: "btn-premium btn-saffron w-100 d-block text-center py-3 fs-6" do %>
                  <i class="fa-solid fa-om me-2"></i> Book This Pooja Seva
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </div>
      
      <!-- Back Link -->
      <div class="bg-light border-top px-4 py-3 d-flex justify-content-between">
        <%= link_to pujas_path, class: "text-muted fw-semibold" do %>
          <i class="fa-solid fa-arrow-left me-1"></i> Back to Catalog
        <% end %>
      </div>
    </div>
  </div>
</div>
