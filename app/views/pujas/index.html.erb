<%
# Helper logic to match category and image tags to Puja titles
def category_for_puja(title)
  t = title.to_s.downcase
  if t.include?("abhishek") || t.include?("rudrabhishek")
    "abhishek"
  elsif t.include?("sarp") || t.include?("dosh") || t.include?("vivah") || t.include?("mangal") || t.include?("grah")
    "dosha"
  elsif t.include?("pitru") || t.include?("shradh") || t.include?("pind") || t.include?("pin_daan") || t.include?("pinda")
    "shradh"
  else
    "other"
  end
end

def local_image_for_puja(title)
  t = title.to_s.downcase
  if t.include?("kaal sarp") || t.include?("kalsarp")
    "kalsarp.webp"
  elsif t.include?("mangal") || t.include?("bhat") || t.include?("ark") || t.include?("vivah")
    "ganeshji.webp"
  elsif t.include?("abhishek") || t.include?("rudrabhishek") || t.include?("mrityunjaya") || t.include?("mahamrityunjaya") || t.include?("shiv")
    "Mahakaleshwar.webp"
  elsif t.include?("pitru") || t.include?("shradh") || t.include?("pind") || t.include?("pin_daan") || t.include?("pinda")
    "pin_daan.webp"
  elsif t.include?("rin") || t.include?("mukti")
    "Shree-Mahakaleshwar-Temple.webp"
  else
    "ganeshji.webp"
  end
end
%>

<!-- 🌸 Static Hero Section -->
<section class="hero-static" style="background-image: url('<%= asset_path('Mahakaleshwar.webp') %>');">
  <div class="overlay"></div>
  <div class="hero-content">
    <h1>🕉 Divine Puja Catalog</h1>
    <p>Perform sacred rituals in the city of Mahakal. Choose from verified pandits, select auspicious muhurats, and receive divine blessings.</p>
  </div>
</section>

<!-- 🌸 Booking Policy Alert -->
<div class="policy-note mb-5 scroll-reveal" data-controller="scroll-reveal">
  <i class="fa-solid fa-circle-info me-2"></i>
  <strong>Important Guidelines:</strong> All online and offline pujas are performed following classical Vedic rules. Devotees pay only after completion.
</div>

<!-- 🌸 Filtering & Listing Container -->
<div data-controller="filter">
  <!-- Search Field -->
  <div class="row justify-content-center mb-4">
    <div class="col-md-8 col-lg-6">
      <div class="position-relative">
        <i class="fa-solid fa-magnifying-glass position-absolute text-muted" style="left: 16px; top: 17px; font-size: 16px;"></i>
        <input type="text" 
               placeholder="Search pooja by title, keyword, or benefits..." 
               class="custom-input" 
               style="padding-left: 45px;"
               data-filter-target="query" 
               data-action="input->filter#search"
               aria-label="Search poojas">
      </div>
    </div>
  </div>

  <!-- Category Tabs -->
  <div class="filter-tabs-wrapper mb-5">
    <button class="filter-tab active" data-filter-target="tab" data-action="click->filter#filterByCategory" data-category="all">
      <i class="fa-solid fa-layer-group me-1"></i> All Rituals
    </button>
    <button class="filter-tab" data-filter-target="tab" data-action="click->filter#filterByCategory" data-category="abhishek">
      <i class="fa-solid fa-water me-1"></i> Abhishek Seva
    </button>
    <button class="filter-tab" data-filter-target="tab" data-action="click->filter#filterByCategory" data-category="dosha">
      <i class="fa-solid fa-shield-halved me-1"></i> Dosha Nivaran
    </button>
    <button class="filter-tab" data-filter-target="tab" data-action="click->filter#filterByCategory" data-category="shradh">
      <i class="fa-solid fa-hands-holding-child me-1"></i> Pitru Tarpan
    </button>
    <button class="filter-tab" data-filter-target="tab" data-action="click->filter#filterByCategory" data-category="other">
      <i class="fa-solid fa-sun me-1"></i> Others
    </button>
  </div>

  <!-- Pujas Listing Grid -->
  <section class="puja-list py-3">
    <% if @pujas.present? %>
      <div class="row g-4">
        <% @pujas.each do |puja| %>
          <div class="col-lg-4 col-md-6 scroll-reveal" 
               data-controller="scroll-reveal"
               data-filter-target="item" 
               data-title="<%= puja.title %>" 
               data-description="<%= puja.description %>"
               data-category="<%= category_for_puja(puja.title) %>">
               
            <div class="pooja-card">
              <!-- Card Image & Price -->
              <div class="card-img-wrap">
                <% if puja.image.attached? %>
                  <%= image_tag puja.image, class: "card-img", alt: puja.title %>
                <% else %>
                  <%= image_tag local_image_for_puja(puja.title), class: "card-img", alt: puja.title %>
                <% end %>
                <div class="price-badge">₹<%= puja.base_price.to_i %></div>
              </div>

              <!-- Card Content -->
              <div class="card-body">
                <h3 class="card-title"><%= puja.title %></h3>
                <p class="card-text"><%= truncate(puja.description, length: 120) %></p>
                
                <!-- Card Metadata -->
                <div class="card-meta mt-auto">
                  <div class="meta-item">
                    <i class="fa-regular fa-clock"></i> <%= puja.duration_minutes || 60 %> mins
                  </div>
                  <div class="meta-item">
                    <i class="fa-solid fa-location-dot"></i> Ujjain Temples
                  </div>
                </div>

                <!-- Book Now Action -->
                <div class="mt-4">
                  <%= link_to puja_path(puja), class: "btn-premium btn-maroon w-100" do %>
                    🙏 View & Book Seva
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5 scroll-reveal" data-controller="scroll-reveal">
        <span class="fs-1 d-block mb-3">🙏</span>
        <p class="text-muted fs-5">No Pujas available in Ujjain right now.</p>
      </div>
    <% end %>
  </section>
</div>

<!-- 🌸 Book Custom Seva CTA Section -->
<div class="bg-white rounded-3 shadow-md border p-4 p-md-5 mt-5 text-center scroll-reveal" data-controller="scroll-reveal">
  <span class="fs-1 d-block mb-3 text-saffron">🕉</span>
  <h2 class="h3 fw-bold mb-3" style="font-family: var(--font-heading);">Didn't find the seva you're looking for?</h2>
  <p class="mx-auto mb-4" style="max-width: 650px; font-size: 1.05rem; color: var(--text-muted); line-height: 1.7; font-family: 'Noto Serif', serif;">
    We can arrange customized Vedic rituals, specific planetary remedies, and personalized offerings at any major temple in Ujjain, tailored to your gotra and family requirements.
  </p>
  <%= link_to new_custom_booking_path, class: "btn-premium btn-saffron px-5 py-3 fs-6 text-decoration-none" do %>
    🕉 Book Custom Seva
  <% end %>
</div>

