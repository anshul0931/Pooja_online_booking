<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12" style="max-width: 760px;">

      <div class="booking-form-card bg-white p-4 p-md-5 rounded-3 shadow border">

        <!-- 🔹 Progress Indicator -->
        <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
          <div class="step-item fw-bold" style="font-size: 13px; color: var(--secondary-color);">
            <span class="d-inline-flex justify-content-center align-items-center rounded-circle me-1 text-white"
              style="width:26px; height:26px; background-color: var(--secondary-color);">1</span>
            Request Custom Seva
          </div>
          <div style="flex-grow:1; height:2px; background-color: var(--gold-color); margin: 0 10px; opacity:0.4;"></div>
          <div class="step-item fw-bold" style="font-size: 13px; color: var(--secondary-color);">
            <span class="d-inline-flex justify-content-center align-items-center rounded-circle me-1 text-white"
              style="width:26px; height:26px; background-color: var(--secondary-color);">2</span>
            Describe Ritual
          </div>
          <div style="flex-grow:1; height:2px; background-color: var(--border-color); margin: 0 10px; opacity:0.4;"></div>
          <div class="step-item text-muted" style="font-size: 13px;">
            <span class="d-inline-flex justify-content-center align-items-center rounded-circle me-1 border text-muted"
              style="width:26px; height:26px; background-color: #f5f5f5;">3</span>
            Confirmation
          </div>
        </div>

        <!-- 🕉 Form Heading -->
        <h1 class="h4 text-center mb-4 fw-bold" style="font-family: var(--font-heading);">
          🕉 Custom Seva Request
        </h1>

        <p class="text-muted text-center mb-4" style="font-family: 'Noto Serif', serif; font-style: italic; font-size: 14px;">
          Describe your personalized ritual requirements. Our coordinator pandits will review it, organize resources, and contact you with details and custom pricing.
        </p>

        <%= form_with model: @custom_booking, url: custom_bookings_path, local: true,
              html: { id: "customBookingForm",
                      data: { controller: "validation", action: "submit->validation#submit" } } do |f| %>

          <!-- ── Section 1: Devotee & Contact Details ── -->
          <h3 class="h6 mb-3 text-uppercase fw-bold border-bottom pb-2" style="letter-spacing: 0.5px; color: var(--text-muted);">
            <i class="fa-solid fa-user me-2" style="color: var(--secondary-color);"></i>
            1. Devotee Details
          </h3>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :user_name, class: "form-label fw-semibold" do %>
                Full Name <span class="text-danger">*</span>
              <% end %>
              <%= f.text_field :user_name,
                    class: "custom-input",
                    placeholder: "Enter your full name",
                    required: true,
                    data: { validation_target: "field",
                            action: "input->validation#validate blur->validation#validate" } %>
              <div class="invalid-feedback">Full name is required.</div>
            </div>

            <div class="col-md-6 mb-3">
              <%= f.label :gotra, class: "form-label fw-semibold" do %>
                Gotra (Ancestry Lineage)
              <% end %>
              <%= f.text_field :gotra,
                    class: "custom-input",
                    placeholder: "e.g. Kashyap, Bhardwaj" %>
            </div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :phone, class: "form-label fw-semibold" do %>
                Phone Number <span class="text-danger">*</span>
              <% end %>
              <%= f.telephone_field :phone,
                    class: "custom-input",
                    placeholder: "e.g. 9876543210",
                    required: true,
                    data: { validation_target: "field",
                            action: "input->validation#validate blur->validation#validate" } %>
              <div class="invalid-feedback">A valid phone number (10–15 digits) is required.</div>
            </div>

            <div class="col-md-6 mb-3">
              <%= f.label :email, class: "form-label fw-semibold" do %>
                Email Address <span class="text-danger">*</span>
              <% end %>
              <%= f.email_field :email,
                    class: "custom-input",
                    placeholder: "devotee@example.com",
                    required: true,
                    data: { validation_target: "field",
                            action: "input->validation#validate blur->validation#validate" } %>
              <div class="invalid-feedback">A valid email address is required.</div>
            </div>
          </div>

          <!-- ── Section 2: Custom Seva Details ── -->
          <h3 class="h6 mt-4 mb-3 text-uppercase fw-bold border-bottom pb-2" style="letter-spacing: 0.5px; color: var(--text-muted);">
            <i class="fa-solid fa-om me-2" style="color: var(--secondary-color);"></i>
            2. Seva Specifications
          </h3>

          <div class="mb-3">
            <%= f.label :seva_description, class: "form-label fw-semibold" do %>
              Describe the Custom Seva / Rituals <span class="text-danger">*</span>
            <% end %>
            <%= f.text_area :seva_description,
                  class: "custom-input",
                  rows: 5,
                  placeholder: "Please describe the specific puja, mantras, deities, or havan requirements you would like performed...",
                  required: true,
                  data: { validation_target: "field",
                          action: "input->validation#validate blur->validation#validate" } %>
            <div class="invalid-feedback">Please describe your custom seva requirements.</div>
          </div>

          <div class="row">
            <div class="col-md-6 mb-3">
              <%= f.label :preferred_date, "Preferred Date (Auspicious Muhurat)", class: "form-label fw-semibold" %>
              <%= f.date_field :preferred_date,
                    class: "custom-input",
                    min: Date.today.to_s %>
            </div>

            <div class="col-md-6 mb-3">
              <%= f.label :location, "Devotee Location / City", class: "form-label fw-semibold" %>
              <%= f.text_field :location,
                    class: "custom-input",
                    placeholder: "e.g. Mumbai, New Delhi" %>
            </div>
          </div>

          <!-- ── Submit ── -->
          <div class="mt-4">
            <%= f.submit "🕉 Submit Custom Seva Request",
                  class: "btn-premium btn-saffron w-100 py-3 fs-6" %>
          </div>

          <p class="text-center text-muted mt-3" style="font-size: 12px;">
            <i class="fa-solid fa-shield-halved me-1 text-success"></i>
            No immediate payment required. We will finalize plans and customize pricing first.
          </p>

        <% end %>
      </div><!-- /.booking-form-card -->

    </div>
  </div>
</div>
