<%
# Helper logic to match local assets contextually to Temple names
def image_for_temple(name)
  n = name.to_s.downcase
  if n.include?("mahakal") || n.include?("mahakaleshwar")
    "Shree-Mahakaleshwar-Temple.webp"
  elsif n.include?("ganesh") || n.include?("chintaman")
    "ganeshji.webp"
  else
    "Mahakaleshwar.webp"
  end
end
%>

<!-- 🌸 Static Hero Section -->
<section class="hero-static" style="background-image: url('<%= asset_path('Shree-Mahakaleshwar-Temple.webp') %>');">
  <div class="overlay"></div>
  <div class="hero-content">
    <h1>🕉 Temples of Ujjain</h1>
    <p>Perform divine rituals in the most sacred power-centers of Avantika. Explore historical temples and book specialized seva.</p>
  </div>
</section>

<!-- 🌸 Booking Policy Alert -->
<div class="policy-note mb-5 scroll-reveal" data-controller="scroll-reveal">
  <i class="fa-solid fa-om me-2"></i>
  <strong>Did you know?</strong> Ujjain (Avantika) is one of the seven sacred moksha-puris and hosts the Shree Mahakaleshwar Jyotirlinga.
</div>

<!-- 🌸 Temples Listing Grid -->
<section class="temple-list py-3">
  <div class="container px-0">
    <% if @temples.present? %>
      <div class="row g-4">
        <% @temples.each do |temple| %>
          <div class="col-lg-4 col-md-6 scroll-reveal" data-controller="scroll-reveal">
            <div class="temple-card">
              <!-- Card Image & City Badge -->
              <div class="card-img-wrap">
                <%= image_tag image_for_temple(temple.name), class: "card-img", alt: temple.name %>
                <div class="city-badge"><%= temple.city || "Ujjain" %></div>
              </div>

              <!-- Card Content -->
              <div class="card-body">
                <h3 class="card-title"><%= temple.name %></h3>
                <p class="text-muted mb-2" style="font-size: 13px;">
                  <i class="fa-solid fa-location-dot text-saffron me-1"></i> <%= temple.address %>
                </p>
                <p class="card-text"><%= truncate(temple.description, length: 120) %></p>
                
                <!-- View Temple Action -->
                <div class="mt-auto pt-3">
                  <%= link_to temple_path(temple), class: "btn-premium btn-maroon w-100" do %>
                    🙏 View Temple & Sevas
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-5 scroll-reveal" data-controller="scroll-reveal">
        <span class="fs-1 d-block mb-3">🙏</span>
        <p class="text-muted fs-5">No Temples registered yet.</p>
      </div>
    <% end %>
  </div>
</section>
