<%
# Query the temple's associated pujas since the controller has it commented out
@pujas = @temple.pujas

# Helper logic to match local assets contextually to Temple / Puja names
def image_for_temple(name)
  n = name.to_s.downcase
  if n.include?("mahakal") || n.include?("mahakaleshwar")
    "Shree-Mahakaleshwar-Temple.webp"
  elsif n.include?("ganesh") || n.include?("chintaman")
    "ganeshji.webp"
  else
    "Mahakaleshwar.webp"
  end
end

def local_image_for_puja(title)
  t = title.to_s.downcase
  if t.include?("kaal sarp") || t.include?("kalsarp")
    "kalsarp.webp"
  elsif t.include?("mangal") || t.include?("bhat") || t.include?("ark") || t.include?("vivah")
    "ganeshji.webp"
  elsif t.include?("abhishek") || t.include?("rudrabhishek") || t.include?("mrityunjaya") || t.include?("mahamrityunjaya") || t.include?("shiv")
    "Mahakaleshwar.webp"
  elsif t.include?("pitru") || t.include?("shradh") || t.include?("pind") || t.include?("pin_daan") || t.include?("pinda")
    "pin_daan.webp"
  elsif t.include?("rin") || t.include?("mukti")
    "Shree-Mahakaleshwar-Temple.webp"
  else
    "ganeshji.webp"
  end
end
%>

<div class="row justify-content-center my-4">
  <div class="col-lg-10">
    <div class="bg-white rounded-3 shadow-md border overflow-hidden">
      <!-- Temple header banner -->
      <div style="position: relative; height: 320px; background-color: #333;">
        <%= image_tag image_for_temple(@temple.name), style: "width:100%; height:100%; object-fit:cover;" %>
        <div style="position: absolute; inset:0; background: linear-gradient(to top, rgba(122,6,22,0.9), transparent 80%);"></div>
        <div style="position: absolute; bottom: 30px; left: 30px; right: 30px; color:#fff;">
          <span style="background-color: var(--gold-color); color:#2D2219; font-weight:700; font-size:12px; padding:4px 10px; border-radius:4px; text-transform:uppercase;"><%= @temple.city || "Ujjain" %></span>
          <h1 class="mt-2 text-white mb-1" style="font-family: var(--font-heading); font-size: 2.2rem; text-shadow: 0 2px 6px rgba(0,0,0,0.5);"><%= @temple.name %></h1>
          <p class="mb-0 text-white-50" style="font-size: 14px;"><i class="fa-solid fa-location-dot me-1"></i> <%= @temple.address %></p>
        </div>
      </div>

      <!-- Description Section -->
      <div class="p-4 p-md-5">
        <h3 class="fw-bold mb-3 border-bottom pb-2">About the Temple</h3>
        <p style="color: var(--text-primary); font-size: 1.05rem; line-height: 1.7; font-family: 'Noto Serif', serif; margin-bottom: 40px;">
          <%= @temple.description %>
        </p>

        <!-- Available Pujas list -->
        <h3 class="fw-bold mb-4 border-bottom pb-2">Available Pooja Sevas at this Temple</h3>
        
        <% if @pujas.present? %>
          <div class="row g-4">
            <% @pujas.each do |puja| %>
              <div class="col-md-6 col-lg-4 scroll-reveal" data-controller="scroll-reveal">
                <div class="pooja-card">
                  <!-- Card Image & Price -->
                  <div class="card-img-wrap">
                    <% if puja.image.attached? %>
                      <%= image_tag puja.image, class: "card-img", alt: puja.title %>
                    <% else %>
                      <%= image_tag local_image_for_puja(puja.title), class: "card-img", alt: puja.title %>
                    <% end %>
                    <div class="price-badge">₹<%= puja.base_price.to_i %></div>
                  </div>

                  <!-- Card Content -->
                  <div class="card-body">
                    <h4 class="card-title" style="font-size: 1.15rem;"><%= puja.title %></h4>
                    <p class="card-text"><%= truncate(puja.description, length: 90) %></p>
                    
                    <div class="mt-auto">
                      <%= link_to new_puja_booking_path(puja), class: "btn-premium btn-saffron w-100 d-block text-center" do %>
                        🕉 Book Now
                      <% end %>
                    </div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="p-4 rounded text-center text-muted" style="background-color: var(--bg-color); border: 1.5px dashed var(--border-color);">
            <i class="fa-solid fa-hands-praying d-block fs-3 mb-2 text-saffron"></i>
            Currently, no online booking sevas are configured specifically for this temple.
          </div>
        <% end %>
      </div>

      <!-- Back Link -->
      <div class="bg-light border-top px-4 py-3">
        <%= link_to temples_path, class: "text-muted fw-semibold" do %>
          <i class="fa-solid fa-arrow-left me-1"></i> Back to Temples List
        <% end %>
      </div>
    </div>
  </div>
</div>
